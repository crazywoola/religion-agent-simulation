# Generic AI provider settings
# provider: openai | moonshot
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o-mini
# Leave empty to use provider default base URL
AI_API_BASE=

# Moonshot / Kimi shortcuts (optional, used when AI_PROVIDER=moonshot)
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2-turbo-preview
MOONSHOT_API_BASE=https://api.moonshot.cn/v1

AI_API_LOG=1
AI_API_LOG_PAYLOAD=0
AI_TRANSFER_AGENT=1
AI_API_TIMEOUT_MS=25000
AI_API_MAX_RETRIES=2
AI_API_RETRY_BASE_DELAY_MS=350

# Legacy aliases (still supported)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_LOG=1
# OPENAI_API_LOG_PAYLOAD=0
# OPENAI_TRANSFER_AGENT=1
# OPENAI_API_TIMEOUT_MS=25000
# OPENAI_API_MAX_RETRIES=2
# OPENAI_API_RETRY_BASE_DELAY_MS=350

# If your system uses http_proxy/https_proxy, keep this as 1
NODE_USE_ENV_PROXY=1
PORT=3000
HOST=0.0.0.0
