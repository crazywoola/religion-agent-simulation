# OpenAI API Key
OPENAI_API_KEY=

# Optional
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_API_LOG=1
OPENAI_API_LOG_PAYLOAD=0
OPENAI_TRANSFER_AGENT=1
OPENAI_API_TIMEOUT_MS=25000
OPENAI_API_MAX_RETRIES=2
OPENAI_API_RETRY_BASE_DELAY_MS=350
# If your system uses http_proxy/https_proxy, keep this as 1
NODE_USE_ENV_PROXY=1
PORT=3000
HOST=0.0.0.0
