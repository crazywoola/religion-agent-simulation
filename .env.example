# AI provider settings
# provider: openai | moonshot
AI_PROVIDER=openai
AI_API_KEY=
# Optional override for selected provider model.
# defaults: openai -> gpt-4o-mini, moonshot -> kimi-k2-turbo-preview
AI_MODEL=
# Optional override for selected provider base URL.
# defaults: openai -> https://api.openai.com/v1, moonshot -> https://api.moonshot.cn/v1
AI_API_BASE=

AI_API_LOG=1
AI_API_LOG_PAYLOAD=0
AI_TRANSFER_AGENT=1
AI_API_TIMEOUT_MS=25000
AI_API_MAX_RETRIES=2
AI_API_RETRY_BASE_DELAY_MS=350

# If your system uses http_proxy/https_proxy, keep this as 1
NODE_USE_ENV_PROXY=1
PORT=3000
HOST=0.0.0.0
